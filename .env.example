## Reference template — see backend/.env.example and frontend/.env.example
## for the actual files that get loaded. This root .env.example is a
## convenience overview of every variable across both packages.

# ---- Supabase (project: fullfront-seo-prod / your own ref) ----
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...      # backend only, NEVER in frontend
SUPABASE_ANON_KEY=sb_publishable_...          # safe in frontend

# ---- Anthropic (Claude API) ----
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Backend ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173            # dev; "*" or empty in prod

# ---- Frontend (Vite — VITE_ prefix to expose to client bundle) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
VITE_API_BASE_URL=http://localhost:4000      # empty in prod (same-origin)
