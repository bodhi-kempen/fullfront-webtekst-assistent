PORT=4000
NODE_ENV=development

# Comma-separated origins, "*" for any, or leave empty.
# Dev default: http://localhost:5173
# Prod default: "*" (same-origin frontend doesn't trigger CORS anyway)
CORS_ORIGIN=http://localhost:5173

# Comma-separated origins allowed to embed the app in an <iframe>.
# Wildcards work (e.g. *.fullfront.nl). Empty = no embedding allowed.
# Example: ALLOWED_FRAME_ORIGINS=https://*.fullfront.nl,https://fullfront.nl
ALLOWED_FRAME_ORIGINS=

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
SUPABASE_ANON_KEY=your-publishable-key

ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Hard cap on Claude spend per Supabase user (USD lifetime). 0 = no cap.
# At default usage ~$1/project, $3 ≈ 3 complete projects per user.
MAX_USAGE_USD_PER_USER=3
